{
  "name": "@citetrack/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Citetrack AI — AI visibility tracking SaaS",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev --parallel",
    "test": "nx run-many -t test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check . && nx run-many -t typecheck",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "clean": "nx reset && rm -rf node_modules/.cache dist tmp"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "nx": "^20.3.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "packageManager": "[email protected]",
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
