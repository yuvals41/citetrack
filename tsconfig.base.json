{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@citetrack/ui": ["packages/ui/src/index.ts"],
      "@citetrack/ui/*": ["packages/ui/src/*"],
      "@citetrack/types": ["packages/types/src/index.ts"],
      "@citetrack/types/*": ["packages/types/src/*"],
      "@citetrack/config": ["packages/config/src/index.ts"],
      "@citetrack/config/*": ["packages/config/src/*"],
      "@citetrack/api-client": ["packages/api-client/src/index.ts"],
      "@citetrack/api-client/*": ["packages/api-client/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".nx"]
}
