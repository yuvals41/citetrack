enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  COMPLETED_WITH_PARTIAL_FAILURES
  FAILED

  @@map("AiVisRunStatus")
}

enum CitationStatus {
  FOUND
  NO_CITATION

  @@map("AiVisCitationStatus")
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  COMPLETED_WITH_PARTIAL_FAILURES
  FAILED

  @@map("AiVisScanStatus")
}

enum ScanMode {
  ONBOARDING
  SCHEDULED

  @@map("AiVisScanMode")
}
