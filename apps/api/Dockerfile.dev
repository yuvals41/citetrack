FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN pip install --no-cache-dir uv

# Dependencies are resolved at container startup (not build time)
# so that volume-mounted source code and local path deps are available.
CMD ["sh", "-c", "uv sync --frozen --no-dev && exec uv run uvicorn ai_visibility.api.routes:app --host 0.0.0.0 --port 8000 --reload"]
