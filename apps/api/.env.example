# Clerk JWT verification
# Get from Clerk Dashboard → API Keys → "Frontend API" field
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
# Comma-separated allowed frontend origins (matches JWT `azp` claim)
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:3002,https://citetrack.ai

# Database (inherited from docker-compose in dev)
DATABASE_URL=postgresql://ai_visibility:ai_visibility@postgres:5432/ai_visibility_db

# Providers
PROVIDERS=openai,anthropic
LOG_LEVEL=INFO
