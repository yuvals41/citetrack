{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@citetrack/ui": ["../../packages/ui/src/index.ts"],
      "@citetrack/ui/*": ["../../packages/ui/src/components/*"],
      "@citetrack/types": ["../../packages/types/src/index.ts"],
      "@citetrack/types/*": ["../../packages/types/src/*"],
      "@citetrack/config": ["../../packages/config/src/index.ts"],
      "@citetrack/config/*": ["../../packages/config/src/*"],
      "@citetrack/api-client": ["../../packages/api-client/src/index.ts"],
      "@citetrack/api-client/*": ["../../packages/api-client/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
